# ── Universal Production Environment Variables Template ──
# Suitable for deployment on AWS, GCP, Azure, Render, Railway, Fly.io, or VPS.

# Database Configuration (Neon PostgreSQL / Managed Postgres)
DATABASE_URL=postgresql+asyncpg://username:password@ep-instance.aws.neon.tech/neondb?ssl=require

# Security Secrets
SECRET_KEY=change_this_to_a_secure_random_production_jwt_secret_key_2026

# Multi-Provider AI LLM Keys
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Gateway Configuration (Point to your production Gateway domain/URL)
NEXT_PUBLIC_GATEWAY_URL=https://api.yourdomain.com
