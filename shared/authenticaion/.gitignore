# ── Auth Service .gitignore ──────────────────────────────────────

# Secrets — NEVER commit
.env
.env.local
.env.production
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyc
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Local SQLite DB (auth uses Neon in prod)
*.db
*.sqlite
*.sqlite3
auth_service.db

# JWT / security artifacts
*.pem
*.key

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
