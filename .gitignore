# ╔══════════════════════════════════════════════════════════════╗
# ║          Athleia.ai — Root Monorepo .gitignore               ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Secrets & credentials (NEVER commit these) ──────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
data/.env
!**/.env.example
!**/.env.template

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
*.egg
*.whl
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Local SQLite databases (use Neon in prod) ───────────────────
*.db
*.sqlite
*.sqlite3

# ── Node / Next.js (client/) ────────────────────────────────────
node_modules/
client/.next/
client/out/
client/.vercel/
client/.turbo/
client/coverage/
client/storybook-static/
.npm

# ── IDE & Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ── OS generated ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── AWS & Cloud ─────────────────────────────────────────────────
.aws/
*.pem
*.key
*.p12
*.pfx

# ── Temporary / build artifacts ─────────────────────────────────
tmp/
temp/
.temp/
*.tmp
*.bak
*.orig
*.rej
