# ── Next.js / Client .gitignore ──────────────────────────────────
# See https://nextjs.org/docs/app/api-reference/config/next-config-js

# Secrets — NEVER commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
!.env.example

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/
build/

# Vercel / deployment
.vercel/
.turbo/

# Testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Storybook
storybook-static/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
