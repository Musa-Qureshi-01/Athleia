# Gateway environment variables
# Copy to .env and fill values before running

# ── Runtime ────────────────────────────────────────────────
ENVIRONMENT=development         # development | staging | production
DEBUG=true

# ── Gateway ────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=info          # debug | info | warning | error

# ── Service Registry ───────────────────────────────────────
REGISTRY_BACKEND=static         # static | consul | kubernetes
SERVICES_CONFIG_PATH=config/services.yaml

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Health Checks ──────────────────────────────────────────
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# ── Proxy ──────────────────────────────────────────────────
MAX_REQUEST_BODY_BYTES=10485760   # 10 MB
