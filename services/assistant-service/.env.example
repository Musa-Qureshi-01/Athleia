# ──────────────────────────────────────────────────────────────────
# Athleia Assistant Service — Safe Environment Configuration
# ──────────────────────────────────────────────────────────────────

PROJECT_NAME="Athleia Enterprise AI Workforce Copilot"
VERSION="1.0.0"
PORT=8010
ENVIRONMENT=development
DEBUG=True

# Connectivity
GATEWAY_URL=http://localhost:8000
AUTH_SERVICE_URL=http://localhost:8008
RETRIEVAL_SERVICE_URL=http://localhost:8001
REASONING_SERVICE_URL=http://localhost:8002
INGESTION_SERVICE_URL=http://localhost:8003
KNOWLEDGE_SERVICE_URL=http://localhost:8005
COMPLIANCE_SERVICE_URL=http://localhost:8006
MAINTENANCE_SERVICE_URL=http://localhost:8007
NOTIFICATION_SERVICE_URL=http://localhost:8009

# Multi-Provider LLM Keys (Inject via Environment Variables)
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
GROQ_API_KEY=
GEMINI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
OLLAMA_BASE_URL=http://localhost:11434

# Database — reads ASSISTANT_DATABASE_URL first, then DATABASE_URL, fallback SQLite
ASSISTANT_DATABASE_URL=postgresql+asyncpg://username:password@ep-instance.aws.neon.tech/neondb?ssl=require

# Features
SEMANTIC_CACHE_ENABLED=true
EXTERNAL_SEARCH_ENABLED=true
GLOBAL_MEMORY_ENABLED=true
